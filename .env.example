# =============================================================================
# Agentic PR Factory — Platform environment
# Copy to `.env` and fill in. Only DAYTONA_API_KEY is required; the rest have
# sensible defaults.
#
# NOTE: The LLM API key and GitHub PAT are NOT set here — users enter them in
# the submit form per job, and they are injected into each sandbox as env vars.
# =============================================================================

# --- Daytona (REQUIRED) ------------------------------------------------------
# Your Daytona API key. Create one at https://app.daytona.io → Settings → API Keys.
# Description: authenticates the SDK that provisions and controls sandboxes.
# Example:     DAYTONA_API_KEY=dtn_5f3c9a2b1e7d4c8f9a0b1c2d3e4f5a6b
DAYTONA_API_KEY=

# --- pi-coder delivery -------------------------------------------------------
# How the pi-coder agent gets into each sandbox.
# Description: "upload" tars the local pi-coding-agent source and uploads it
#              (works without publishing the repo). "git" clones PI_CODER_REPO_URL.
# Allowed:     upload | git
# Example:     PI_CODER_SOURCE=upload
PI_CODER_SOURCE=upload

# Git URL of the pi-coder repo. Only used when PI_CODER_SOURCE=git. Leave empty
# for upload mode.
# Description: cloned into /opt/pi-coder inside the sandbox, then `bun install`.
# Example:     PI_CODER_REPO_URL=https://github.com/your-org/pi-coding-agent.git
PI_CODER_REPO_URL=

# Path to the local pi-coder source. Only used when PI_CODER_SOURCE=upload.
# Description: resolved relative to the platform/ dir; tarred (minus node_modules)
#              and uploaded to the sandbox.
# Example:     PI_CODER_LOCAL_PATH=../pi-coding-agent
PI_CODER_LOCAL_PATH=../pi-coding-agent

# --- Sandbox sizing ----------------------------------------------------------
# Base container image for the sandbox (Node preinstalled; bun/git/rg added at bootstrap).
# Description: any Daytona-supported image; node:22-bookworm is the tested default.
# Example:     SANDBOX_IMAGE=node:22-bookworm
SANDBOX_IMAGE=node:22-bookworm

# vCPUs allocated to each sandbox.
# Description: integer count of cores.
# Example:     SANDBOX_CPU=2
SANDBOX_CPU=2

# RAM in GiB allocated to each sandbox.
# Description: integer gigabytes.
# Example:     SANDBOX_MEMORY=4
SANDBOX_MEMORY=4

# Disk in GiB allocated to each sandbox.
# Description: integer gigabytes; must fit the cloned repo + dependencies.
# Example:     SANDBOX_DISK=10
SANDBOX_DISK=10

# --- Supabase (conversation persistence) -------------------------------------
# Optional: if unset, the app runs memory-only (conversations lost on restart).
# Run supabase/schema.sql in the Supabase SQL editor first.
#
# Project URL — Supabase dashboard → Project Settings → API → Project URL.
# Example:     SUPABASE_URL=https://abcdefghijklmnop.supabase.co
SUPABASE_URL=

# SERVICE ROLE key (server-side only — bypasses RLS; never expose to the browser).
# Supabase dashboard → Project Settings → API → service_role secret.
# Example:     SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=
